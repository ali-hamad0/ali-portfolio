# ── PostgreSQL (Supabase) ─────────────────────────────────────────
# Your string was: postgresql://postgres:[YOUR-PASSWORD]@db.dnpdsiommpknbqguawlp.supabase.co:5432/postgres
# Two changes needed:
#   1. Replace [YOUR-PASSWORD] with your real Supabase DB password
#   2. Change postgresql:// → postgresql+asyncpg://
DATABASE_URL=postgresql+asyncpg://postgres:REPLACE_WITH_YOUR_PASSWORD@db.dnpdsiommpknbqguawlp.supabase.co:5432/postgres

# ── Admin ─────────────────────────────────────────────────────────
ADMIN_PASSWORD=choose_something_strong

# ── JWT (run in terminal to generate) ────────────────────────────
# python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=paste_result_here

# ── Uploadcare ────────────────────────────────────────────────────
# Sign up at uploadcare.com → Dashboard → API Keys
UPLOADCARE_PUBLIC_KEY=your_public_key
UPLOADCARE_SECRET_KEY=your_secret_key
